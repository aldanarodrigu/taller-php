[Unit]
Description=Laravel Reverb WebSocket Server
After=network.target redis-server.service
Requires=redis-server.service

[Service]
Type=simple
User=ubuntu
Group=www-data
WorkingDirectory=/var/www/taller-php
ExecStart=/usr/bin/php artisan reverb:start --host=0.0.0.0 --port=6001 --debug
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
